---
import { porQueVenir } from "@/data/porQuevenir";

const highlightedLetter = porQueVenir.highlightedLetter;
const letterIndex = porQueVenir.title.indexOf(highlightedLetter);
const titleBefore =
  letterIndex >= 0
    ? porQueVenir.title.slice(0, letterIndex)
    : porQueVenir.title;
const titleAfter =
  letterIndex >= 0
    ? porQueVenir.title.slice(letterIndex + highlightedLetter.length)
    : "";
---

<style>
  :global(:root) {
    --color-text-dark: #4a4a4a;
    --color-text-body: #8a8a8a;
    --color-line: #2b2b2b;
    --color-line-light: #d9d9d9;
  }

  .why-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 40px;
    box-sizing: border-box;
    font-family: var(--font-body);
  }

  .why-section * {
    box-sizing: border-box;
  }

  .why-section__eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-text-dark);
    margin: 0 0 16px;
  }

  .why-section__title {
    font-size: 40px;
    font-weight: 700;
    color: var(--color-text-dark);
    margin: 0 0 40px;
  }

  .why-section__title u {
    text-decoration: underline;
  }

  .why-section__divider {
    border: none;
    border-top: 2px solid var(--color-line);
    margin: 0 0 40px;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .why-item {
    padding: 0 40px;
    border-left: 1px solid var(--color-line-light);
  }

  .why-item:first-child {
    padding-left: 0;
    border-left: none;
  }

  .why-item__number {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text-dark);
    margin: 0 0 12px;
  }

  .why-item__title {
    font-size: 22px;
    font-weight: 600;
    color: var(--color-text-dark);
    margin: 0 0 14px;
  }

  .why-item__desc {
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-text-body);
    margin: 0;
  }

  @media (width < 64rem) {
    .why-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .why-item {
      padding: 0;
      border-left: none;
      padding-top: 24px;
      border-top: 1px solid var(--color-line-light);
    }

    .why-item:first-child {
      padding-top: 0;
      border-top: none;
    }

    .why-section__title {
      font-size: 30px;
    }
  }
</style>

<section class="why-section">
  <p class="why-section__eyebrow">{porQueVenir.eyebrow}</p>
  <h2 class="why-section__title">
    {titleBefore}{letterIndex >= 0 && <u>{highlightedLetter}</u>}{titleAfter}
  </h2>

  <hr class="why-section__divider" />

  <div class="why-grid">
    {
      porQueVenir.items.map((item) => (
        <div class="why-item">
          <p class="why-item__number">{item.number}</p>
          <h3 class="why-item__title">{item.title}</h3>
          <p class="why-item__desc">{item.description}</p>
        </div>
      ))
    }
  </div>
</section>
