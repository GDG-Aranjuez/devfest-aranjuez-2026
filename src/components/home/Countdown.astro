---
import { site } from "@/data/site";

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div
  class:list={["hero-countdown flex items-start gap-size-5", className]}
  data-event-start={site.event.startDateTime}
  aria-label="Cuenta atrás para el evento"
  role="timer"
>
  <div class="flex flex-col items-center justify-center gap-size-1">
    <span class="countdown-num" data-countdown="days">--</span>
    <span class="countdown-label">días</span>
  </div>
  <span class="countdown-sep" aria-hidden="true">:</span>
  <div class="flex flex-col items-center justify-center gap-size-1">
    <span class="countdown-num" data-countdown="hours">--</span>
    <span class="countdown-label">horas</span>
  </div>
  <span class="countdown-sep" aria-hidden="true">:</span>
  <div class="flex flex-col items-center justify-center gap-size-1">
    <span class="countdown-num" data-countdown="minutes">--</span>
    <span class="countdown-label">minutos</span>
  </div>
  <span class="countdown-sep" aria-hidden="true">:</span>
  <div class="flex flex-col items-center justify-center gap-size-1">
    <span class="countdown-num" data-countdown="seconds">--</span>
    <span class="countdown-label">segundos</span>
  </div>
</div>

<script>
  let countdownInterval: ReturnType<typeof setInterval> | undefined;

  function eventStartMs(root: Element): number | null {
    const raw = root.getAttribute("data-event-start");
    if (!raw) return null;
    const ms = new Date(raw).getTime();
    return Number.isNaN(ms) ? null : ms;
  }

  function tick() {
    document.querySelectorAll(".hero-countdown").forEach((root) => {
      const start = eventStartMs(root);
      if (start === null) return;

      const diff = Math.max(0, start - Date.now());
      const days = Math.floor(diff / 86_400_000);
      const hours = Math.floor((diff % 86_400_000) / 3_600_000);
      const minutes = Math.floor((diff % 3_600_000) / 60_000);
      const seconds = Math.floor((diff % 60_000) / 1_000);

      const set = (key: string, val: number) => {
        const el = root.querySelector(`[data-countdown="${key}"]`);
        if (el) el.textContent = String(val);
      };
      set("days", days);
      set("hours", hours);
      set("minutes", minutes);
      set("seconds", seconds);
    });
  }

  function initCountdown() {
    tick();
    if (countdownInterval) clearInterval(countdownInterval);
    countdownInterval = setInterval(tick, 1_000);
  }

  initCountdown();
  document.addEventListener("astro:page-load", initCountdown);
</script>
