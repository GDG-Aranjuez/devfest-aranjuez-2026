---
import { tickerItems } from "@/data/ticker";

const LAP_REPEATS = 2;
const lap = Array.from({ length: LAP_REPEATS }, () => [...tickerItems]).flat();
const belts = [0, 1] as const;
---

<section class="bg-page" aria-label="Temas del evento">
  <div class="overflow-hidden py-size-8 lg:py-size-10">
    <div
      class="relative left-1/2 w-[135vw] origin-center -translate-x-1/2 rotate-[3deg] bg-inverse text-on-brand type-subtitle lg:w-[120vw]"
    >
      <div class="flex w-max animate-ticker motion-reduce:animate-none">
        {
          belts.map((copy) => (
            <div
              class="flex shrink-0 items-center gap-size-6 whitespace-nowrap py-size-7 pr-size-6 lg:gap-size-7 lg:pr-size-7"
              aria-hidden={copy === 0 ? undefined : "true"}
            >
              {lap.map((item) => (
                <>
                  <span>{item}</span>
                  <span aria-hidden="true">·</span>
                </>
              ))}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
