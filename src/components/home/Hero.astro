---
import Countdown from "@/components/home/Countdown.astro";
import CtaNote from "@/components/shared/CtaNote.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import { hero } from "@/data/hero";
import { withBase } from "@/utils/path";
---

<Section
  class="bg-page !py-size-11 lg:!py-size-15"
  ariaLabelledby="hero-heading"
>
  <Container>
    <div class="flex flex-col lg:flex-row lg:items-center lg:gap-size-8">
      <div class="flex flex-1 min-w-0 flex-col items-stretch">
        <p class="type-eyebrow pb-size-6 text-body">
          <span class="font-light">{hero.dateLead}</span>
          {" "}
          <span class="font-medium">{hero.dateYear}</span>
        </p>

        <h1
          id="hero-heading"
          class="type-h1 max-w-[500px] pb-size-7 lg:max-w-[689px]"
        >
          <span class="text-heading">{hero.titleLead}{" "}</span>
          <span class="text-highlighted">{hero.titleHighlight}</span>
        </h1>

        <p
          class="type-subtitle max-w-prose pb-size-7 text-heading lg:max-w-[480px]"
        >
          {hero.subtitle}
        </p>

        <Countdown
          class="w-full justify-center pb-size-9 pt-size-6 lg:justify-start lg:pb-size-7 lg:pt-size-5"
        />

        <div
          class="flex w-full max-w-[380px] flex-col items-stretch self-center lg:max-w-none lg:self-start"
        >
          <CtaNote
            href={hero.cta.href}
            label={hero.cta.label}
            footnote={hero.footnote}
            noteAlign="start"
          />
        </div>

        <div class="flex w-full justify-center pt-size-6 lg:hidden">
          <a
            href={hero.benefit.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex max-w-full items-center rounded-full border-[0.5px] border-pill-stroke px-size-3 py-size-4 text-body"
          >
            <img
              src={withBase("/brand/paw-icon.svg")}
              alt=""
              width="24"
              height="28"
              class="h-7 w-6 shrink-0"
              aria-hidden="true"
            />
            <span class="type-caption px-size-5 py-size-1 whitespace-nowrap">
              {hero.benefit.label}
            </span>
          </a>
        </div>
      </div>

      <div
        class="hero-visual mt-size-10 hidden min-h-[400px] w-[327px] shrink-0 self-stretch rounded-sm bg-surface-raised/60 lg:mt-0 lg:block lg:min-h-[520px]"
        role="img"
        aria-label={hero.visual.ariaLabel}
      >
      </div>
    </div>
  </Container>
</Section>

<style>
  .hero-visual {
    background-image: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-heading) 40%, transparent) 1.5px,
      transparent 1.5px
    );
    background-size: var(--spacing-size-6) var(--spacing-size-6);
  }
</style>
