---
import Icon from "@/components/ui/Icon.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import { speakersSection } from "@/data/speakers";
import { withBase } from "@/utils/path";
---

<Section class="bg-page" ariaLabelledby="speakers-heading">
  <Container>
    <div class="mx-auto w-full max-w-[1200px]">
      <p class="type-eyebrow-medium pb-size-4 text-muted"
        >{speakersSection.label}</p
      >

      <h2 id="speakers-heading" class="type-h2 pb-size-9 lg:pb-size-10">
        {speakersSection.heading}
      </h2>

      <div
        class="grid grid-cols-1 gap-size-7 sm:grid-cols-2 lg:grid-cols-4 lg:gap-size-8"
      >
        {
          speakersSection.speakers.map((speaker) => (
            <article class="flex h-full flex-col overflow-hidden rounded-sm border border-stroke bg-surface lg:h-[430px]">
              <img
                src={withBase(speaker.image.src)}
                alt={speaker.image.alt}
                width="420"
                height="315"
                loading="lazy"
                class="aspect-[4/3] w-full object-cover"
              />

              <div class="flex flex-1 flex-col gap-size-4 p-size-6">
                <h3 class="type-h5 text-heading">{speaker.name}</h3>
                <p class="type-paragraph-s text-subtitle">{speaker.role}</p>
                <p class="type-paragraph-s text-body">{speaker.description}</p>

                <div class="mt-auto flex items-center gap-size-4 pt-size-2">
                  {speaker.socialLinks.map((socialLink) => (
                    <a
                      href={socialLink.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={socialLink.label}
                      class="inline-flex size-9 items-center justify-center rounded-sm bg-surface-raised text-subtitle transition-colors hover:bg-surface-raised/80 hover:text-heading"
                    >
                      <Icon name={socialLink.icon} size={16} />
                    </a>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </Container>
</Section>
