---
import LinkList from "@/components/layout/LinkList.astro";
import SocialLinks from "@/components/layout/SocialLinks.astro";
import Container from "@/components/ui/Container.astro";
import { footerMeta, footerMobileNav, footerSections } from "@/data/footer";
import { withBase } from "@/utils/path";
---

<footer class="bg-page border-t border-stroke">
  <div class="md:hidden">
    <Container class="flex flex-col gap-size-8 pt-size-12 pb-size-9">
      <div class="flex flex-col gap-size-5">
        <a href={withBase("/")} class="inline-flex">
          <img
            src={withBase("/brand/imagotipo-navbar.png")}
            alt="FresON fest"
            width="110"
            height="40"
            class="h-10 w-auto"
          />
        </a>
        <p class="type-caption text-muted">
          {footerMeta.tagline}
        </p>
        <SocialLinks variant="mobile" />
      </div>

      <div class="panel">
        <LinkList links={footerMobileNav} />
      </div>

      <hr class="border-stroke" />

      <div class="flex flex-col gap-size-2">
        <a
          href={withBase(footerMeta.help.href)}
          class="flex items-center gap-size-2 py-size-5 type-paragraph-m text-muted hover:text-heading transition-colors"
        >
          <img
            src={withBase("/help-icon.png")}
            alt=""
            width="20"
            height="20"
            class="size-5 opacity-60"
            aria-hidden="true"
          />
          {footerMeta.help.label}
        </a>
        <a
          href={withBase(footerMeta.conduct.href)}
          class="py-size-5 type-paragraph-m text-subtitle hover:text-heading transition-colors"
        >
          {footerMeta.conduct.label}
        </a>
        <p class="py-size-5 type-caption text-muted">
          {footerMeta.copyright}
        </p>
      </div>
    </Container>
  </div>

  <div class="hidden md:flex w-full">
    <Container
      class="flex flex-col gap-size-12 py-size-13 md:px-(--section-px-desktop)"
    >
      <div class="grid grid-cols-4 gap-0 w-full">
        <div class="flex flex-col gap-size-4 pr-size-4">
          <a href={withBase("/")} class="inline-flex">
            <img
              src={withBase("/brand/imagotipo-navbar.png")}
              alt="FresON fest"
              width="145"
              height="51"
              class="h-10 w-auto"
            />
          </a>
          <p class="type-paragraph-m text-muted">
            {footerMeta.tagline}
          </p>
          <SocialLinks variant="desktop" />
        </div>

        {
          footerSections.map(({ title, links }) => (
            <div class="flex flex-col gap-size-4">
              <h3 class="type-paragraph-m font-medium text-heading">{title}</h3>
              <ul class="flex flex-col gap-size-4">
                {links.map(({ href, label }) => (
                  <li>
                    <a
                      href={withBase(href)}
                      class="type-paragraph-m text-subtitle hover:text-heading transition-colors"
                    >
                      {label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <div
        class="flex items-center justify-between border-t border-stroke pt-size-6"
      >
        <a
          href={withBase(footerMeta.conduct.href)}
          class="type-paragraph-m text-subtitle hover:text-heading transition-colors"
        >
          {footerMeta.conduct.label}
        </a>
        <a
          href={withBase(footerMeta.help.href)}
          class="flex items-center gap-size-2 type-caption text-muted hover:text-heading transition-colors"
        >
          <img
            src={withBase("/help-icon.png")}
            alt=""
            width="20"
            height="20"
            class="size-5 opacity-60"
            aria-hidden="true"
          />
          {footerMeta.help.label}
        </a>
        <span class="type-paragraph-m text-muted">{footerMeta.copyright}</span>
      </div>
    </Container>
  </div>
</footer>
