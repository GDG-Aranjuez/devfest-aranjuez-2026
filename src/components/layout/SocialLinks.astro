---
import Icon from "@/components/ui/Icon.astro";
import { socialLinks } from "@/data/footer";
import type { IconName } from "@/types/icon";

interface Props {
  variant?: "mobile" | "desktop";
}

const { variant = "mobile" } = Astro.props;

const linkClass =
  variant === "mobile"
    ? "size-12 flex items-center justify-center text-subtitle hover:text-heading transition-colors"
    : "size-10 flex items-center justify-center rounded-sm bg-surface text-subtitle hover:text-heading hover:bg-surface-raised transition-colors";

const iconSizes: Record<"mobile" | "desktop", Record<IconName, number>> = {
  mobile: { linkedin: 20, x: 18 },
  desktop: { linkedin: 16, x: 16 },
};
---

<div class:list={["flex gap-size-5", variant === "desktop" && "pt-size-2"]}>
  {
    socialLinks.map(({ href, label, icon }) => (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={label}
        class={linkClass}
      >
        <Icon name={icon} size={iconSizes[variant][icon]} />
      </a>
    ))
  }
</div>
