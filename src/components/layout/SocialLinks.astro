---
import Icon from "@/components/ui/Icon.astro";
import { socialLinks } from "@/data/footer";
import type { IconName } from "@/types/icon";

const iconSizes: Record<IconName, number> = {
  linkedin: 36,
  x: 36,
  instagram: 32,
};
---

<div class="flex items-center gap-size-4">
  {
    socialLinks.map(({ href, label, icon }) => (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={label}
        class="size-12 flex items-center text-heading hover:text-brand transition-colors"
      >
        <Icon name={icon} size={iconSizes[icon]} />
      </a>
    ))
  }
</div>
