---
import DesktopNav from "@/components/layout/DesktopNav.astro";
import MobileNav from "@/components/layout/MobileNav.astro";
import Container from "@/components/ui/Container.astro";
import { mainNavLinks, ticketsCta } from "@/data/nav";
import { withBase } from "@/utils/path";

const pathname = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 w-full bg-gdg-surface border-b border-gdg-border/60"
>
  <Container
    class="h-(--nav-height) flex items-center justify-between md:px-(--section-px-desktop)"
  >
    <a href={withBase("/")} class="shrink-0 flex items-center h-(--nav-height)">
      <img
        src={withBase("/logo.png")}
        alt="GDG Aranjuez"
        width="72"
        height="40"
        class="h-10 w-auto"
      />
    </a>

    <DesktopNav links={mainNavLinks} pathname={pathname}>
      <a
        href={withBase(ticketsCta.href)}
        class="inline-flex items-center h-10 px-6 rounded-sm bg-gdg-primary text-white text-[15px] font-medium hover:bg-gdg-primary/90 transition-colors"
      >
        {ticketsCta.label}
      </a>
    </DesktopNav>

    <button
      id="nav-toggle"
      type="button"
      class="lg:hidden flex items-center justify-center size-14 -mr-4 text-gdg-text-secondary hover:text-gdg-text transition-colors"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <svg
        id="icon-open"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M3 6h18M3 12h18M3 18h18"></path>
      </svg>
      <svg
        id="icon-close"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        class="hidden"
        aria-hidden="true"
      >
        <path d="M6 6l12 12M18 6L6 18"></path>
      </svg>
    </button>
  </Container>
</header>

<MobileNav
  links={mainNavLinks}
  pathname={pathname}
  ticketsHref={ticketsCta.href}
  ticketsLabel={ticketsCta.label}
/>
