---
import DesktopNav from "@/components/layout/DesktopNav.astro";
import MobileNav from "@/components/layout/MobileNav.astro";
import Container from "@/components/ui/Container.astro";
import { mainNavLinks, ticketsCta } from "@/data/nav";
import { withBase } from "@/utils/path";

const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full bg-page">
  <Container
    class="flex items-center justify-between pt-size-7 pb-size-2 lg:py-size-6"
  >
    <a href={withBase("/")} class="shrink-0 flex items-center">
      <img
        src={withBase("/brand/imagotipo-navbar.png")}
        alt="FresON fest"
        width="145"
        height="51"
        class="h-10 w-auto lg:h-[51px]"
      />
    </a>

    <DesktopNav links={mainNavLinks} pathname={pathname}>
      <a href={withBase(ticketsCta.href)} class="btn-primary h-10">
        {ticketsCta.label}
      </a>
    </DesktopNav>

    <button
      id="nav-toggle"
      type="button"
      class="lg:hidden flex items-center justify-center size-size-11 text-heading hover:text-link transition-colors"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <svg
        id="icon-open"
        width="36"
        height="36"
        viewBox="0 0 36 36"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M6 7.5h24M6 18h24M6 28.5h24"></path>
      </svg>
      <svg
        id="icon-close"
        width="36"
        height="36"
        viewBox="0 0 36 36"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        class="hidden"
        aria-hidden="true"
      >
        <path d="M9 9l18 18M27 9L9 27"></path>
      </svg>
    </button>
  </Container>
</header>

<MobileNav
  links={mainNavLinks}
  pathname={pathname}
  ticketsHref={ticketsCta.href}
  ticketsLabel={ticketsCta.label}
/>
