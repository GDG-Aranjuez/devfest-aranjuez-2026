---
import type { NavLink } from "@/types/nav";
import { isActive, navLinkClass } from "@/utils/nav";
import { withBase } from "@/utils/path";

interface Props {
  links: NavLink[];
  pathname: string;
}

const { links, pathname } = Astro.props;
const linkBase = "text-[15px] font-medium leading-none transition-colors";
---

<nav
  class="hidden lg:flex items-center gap-8"
  aria-label="Navegación principal"
>
  {
    links.map(({ href, label }) => {
      const active = isActive(pathname, href);
      return (
        <a
          href={withBase(href)}
          class={navLinkClass(active, linkBase)}
          aria-current={active ? "page" : undefined}
        >
          {label}
        </a>
      );
    })
  }
  <slot />
</nav>
