---
import { iconPaths, type IconName } from "@/types/icon";

interface Props {
  name: IconName;
  size?: number;
  class?: string;
}

const { name, size = 24, class: className = "" } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="currentColor"
  class={className}
  aria-hidden="true"
>
  <path d={iconPaths[name]}></path>
</svg>
